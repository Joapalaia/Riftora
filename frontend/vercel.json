{
  "rewrites": [
    { "source": "/search",   "destination": "/search.html"   },
    { "source": "/escolher", "destination": "/escolher.html" },
    { "source": "/maestria", "destination": "/maestria.html" },
    { "source": "/stats",    "destination": "/stats.html"    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}